# ============================================================
# DocMind — 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env：  cp backend/.env.example backend/.env
#   2. 填入实际凭证和配置
#   3. docker-compose 会自动从 backend/.env 读取环境变量
#
# 注意：.env 文件在 backend/ 目录下，不在项目根目录
# ============================================================

# ── 应用 ──
APP_NAME=DocMind
DEBUG=false
ENV=production

# ── MySQL ──
# Docker 部署时 MYSQL_HOST 设为服务名 "mysql"（docker-compose 内部 DNS 解析）
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=docmind
MYSQL_PASSWORD=your_strong_password
MYSQL_DATABASE=docmind

# ── ChromaDB ──
# 容器内路径，通过 docker-compose 挂卷持久化
CHROMA_PERSIST_DIR=./chroma_data

# ── LLM（OpenAI 兼容接口 — DeepSeek）──
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-xxx
LLM_MODEL=deepseek-v4-pro
LLM_FLASH_MODEL=deepseek-v4-flash

# ── Embedding（DashScope）──
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-v3

# ── Rerank（DashScope，Phase 5.5 启用）──
RERANK_API_KEY=
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1
RERANK_MODEL=qwen3-rerank

# ── JWT ──
# ⚠️ 生产环境必须更换为 64 字符随机字符串！
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_SECRET_KEY=

# ── Redis ──
# Docker 部署时 REDIS_URL 设为服务名 "redis"（docker-compose 内部 DNS 解析）
REDIS_URL=redis://redis:6379/0

# ── Celery ──
# Docker 部署时 broker/backend 使用 redis 服务名
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── 文件存储 ──
# 容器内路径，通过 docker-compose 挂卷持久化
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,md,txt

# ── CORS ──
# 生产环境设为实际访问域名（Nginx 代理后浏览器看到的 URL）
# 多个域名逗号分隔，例如：https://docmind.example.com,https://doc.example.com
CORS_ORIGINS=http://localhost

